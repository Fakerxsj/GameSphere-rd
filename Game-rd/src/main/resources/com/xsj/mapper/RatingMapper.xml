<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xsj.mapper.RatingMapper">

    <resultMap id="BaseResultMap" type="com.xsj.entity.Rating">
            <id property="id" column="id" />
            <result property="userId" column="user_id" />
            <result property="gameId" column="game_id" />
            <result property="score" column="score" />
            <result property="content" column="content" />
            <result property="upvoteCount" column="upvote_count" />
            <result property="downvoteCount" column="downvote_count" />
            <result property="isOfficial" column="is_official" />
            <result property="status" column="status" />
            <result property="createTime" column="create_time" />
            <result property="updateTime" column="update_time" />
    </resultMap>

    <sql id="Base_Column_List">
        id,user_id,game_id,score,content,upvote_count,
        downvote_count,is_official,status,create_time,update_time
    </sql>
</mapper>
