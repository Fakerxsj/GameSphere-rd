<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xsj.mapper.CommentMapper">

    <resultMap id="BaseResultMap" type="com.xsj.entity.Comment">
        <id property="id" column="id" />
        <result property="userId" column="user_id" />
        <result property="gameId" column="game_id" />
        <result property="parentId" column="parent_id" />
        <result property="content" column="content" />
        <result property="images" column="images" />
        <result property="likeCount" column="like_count" />
        <result property="replyCount" column="reply_count" />
        <result property="status" column="status" />
        <result property="isTop" column="is_top" />
        <result property="createTime" column="create_time" />
        <result property="updateTime" column="update_time" />
    </resultMap>

    <resultMap id="CommentVOMap" type="com.xsj.vo.CommentVO">
        <id property="id" column="id" />
        <result property="userId" column="user_id" />
        <result property="userNickname" column="user_nickname" />
        <result property="userAvatar" column="user_avatar" />
        <result property="gameId" column="game_id" />
        <result property="content" column="content" />
        <result property="likeCount" column="like_count" />
        <result property="replyCount" column="reply_count" />
        <result property="isLiked" column="is_liked" />
        <result property="createTime" column="create_time" />
    </resultMap>

    <sql id="Base_Column_List">
        id,user_id,game_id,parent_id,content,images,
        like_count,reply_count,status,is_top,create_time,
        update_time
    </sql>

    <select id="selectCommentsWithUser" resultMap="CommentVOMap">
        SELECT
            c.id,
            c.user_id,
            c.game_id,
            c.parent_id,
            c.content,
            c.images,
            c.like_count,
            c.reply_count,
            c.is_top,
            c.create_time,
            u.nickname AS user_nickname,
            u.avatar AS user_avatar,
            0 AS is_liked
        FROM comment c
                 LEFT JOIN user u ON c.user_id = u.id
        WHERE c.game_id = #{gameId}
          AND c.parent_id = 0
          AND c.status = 1
        ORDER BY c.is_top DESC, c.create_time DESC
    </select>

    <select id="selectReplies" resultMap="CommentVOMap">
        SELECT
            c.id,
            c.user_id,
            c.game_id,
            c.parent_id,
            c.content,
            c.images,
            c.like_count,
            c.reply_count,
            c.create_time,
            u.nickname AS user_nickname,
            u.avatar AS user_avatar,
            0 AS is_liked
        FROM comment c
                 LEFT JOIN user u ON c.user_id = u.id
        WHERE c.parent_id = #{parentId}
          AND c.status = 1
        ORDER BY c.create_time ASC
    </select>
</mapper>
