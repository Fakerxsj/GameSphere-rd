<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xsj.mapper.FriendMapper">

    <resultMap id="BaseResultMap" type="com.xsj.entity.Friend">
        <id property="id" column="id" />
        <result property="userId" column="user_id" />
        <result property="friendId" column="friend_id" />
        <result property="remark" column="remark" />
        <result property="status" column="status" />
        <result property="createTime" column="create_time" />
        <result property="updateTime" column="update_time" />
    </resultMap>

    <sql id="Base_Column_List">
        id,user_id,friend_id,remark,status,create_time,
        update_time
    </sql>

    <select id="selectFriendsByUserId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM friend
        WHERE user_id = #{userId} AND status = 1
        ORDER BY update_time DESC
    </select>

    <select id="existsFriendship" resultType="java.lang.Boolean">
        SELECT COUNT(1) > 0
        FROM friend
        WHERE user_id = #{userId} AND friend_id = #{friendId} AND status = 1
    </select>

    <delete id="deleteFriendship">
        DELETE FROM friend
        WHERE (user_id = #{userId} AND friend_id = #{friendId})
           OR (user_id = #{friendId} AND friend_id = #{userId})
    </delete>

</mapper>
